# --- LLM (Groq, free tier) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Web Search ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- Compliance / Moderation (optional) ---
# If not set, the Compliance Agent falls back to a built-in rule-based checker.
OPENAI_API_KEY=

# --- Firebase Auth ---
# Path to your Firebase service-account JSON (download from Firebase console)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- RAG ---
CHROMA_PERSIST_DIR=./vector_db
PDF_FOLDER=./pdfs
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- App ---
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
